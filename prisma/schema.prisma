generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["views"]
}

datasource db {
  provider = "postgresql"
  url      = env("PRISMA_DATABASE_URL")
}

model User {
  id                   String                 @id @default(cuid())
  email                String                 @unique
  isActive             Boolean                @default(false)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  emailVerified        DateTime?
  firstName            String?
  lastName             String?
  phone                String?
  lastLoginAt          DateTime?
  image                String?
  name                 String?
  businesses           Business[]
  calendarIntegrations CalendarIntegration[]
  forms                Form[]
  subscriptions        Subscription[]
  sentInvitations      TeamMemberInvitation[] @relation("Inviter")
  teamMemberships      TeamMember[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_token")
}

model Business {
  id            String                 @id @default(cuid())
  ownerId       String
  name          String
  description   String?
  businessType  String?
  logoUrl       String?
  primaryColor  String?
  isActive      Boolean                @default(true)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  appointments  Appointment[]
  breakTimes    BreakTime[]
  businessHours BusinessHours[]
  customers     Customer[]
  owner         User                   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  forms         Form[]
  services      Service[]
  invitations   TeamMemberInvitation[]
  teamMembers   TeamMember[]
  timeOffs      TimeOff[]
  integrations  WebsiteIntegration[]

  @@index([ownerId])
  @@index([businessType])
  @@map("businesses")
}

model TeamMember {
  id           String        @id @default(cuid())
  businessId   String
  userId       String
  role         String
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  timeOffs     TimeOff[]
  services     Service[]

  @@unique([businessId, userId])
  @@index([businessId])
  @@index([userId])
  @@map("team_members")
}

model BusinessHours {
  id         String   @id @default(cuid())
  businessId String
  dayOfWeek  String[]
  openTime   String
  closeTime  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, dayOfWeek])
  @@index([businessId, dayOfWeek])
  @@map("business_hours")
}

model BreakTime {
  id         String   @id @default(cuid())
  businessId String
  dayOfWeek  String[]
  startTime  String
  endTime    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, dayOfWeek])
  @@index([businessId, dayOfWeek])
  @@map("break_times")
}

model TimeOff {
  id           String      @id @default(cuid())
  businessId   String
  teamMemberId String?
  startDate    DateTime    @db.Date
  endDate      DateTime    @db.Date
  startTime    DateTime?   @db.Time(6)
  endTime      DateTime?   @db.Time(6)
  description  String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  business     Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  teamMember   TeamMember? @relation(fields: [teamMemberId], references: [id], onDelete: SetNull)

  @@map("time_off")
}

model Form {
  id                      String               @id @default(cuid())
  businessId              String
  userId                  String?
  serviceId               String               @unique
  name                    String
  description             String?
  isTemplate              Boolean              @default(false)
  templateType            String?
  confirmationMessage     String?
  allowCancellation       Boolean              @default(true)
  cancellationNoticeHours Int                  @default(24)
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  content                 String               @default("[]")
  url                     String?              @unique
  status                  FormStatus           @default(DRAFT)
  appointments            Appointment[]
  business                Business             @relation(fields: [businessId], references: [id])
  service                 Service              @relation(fields: [serviceId], references: [id])
  user                    User?                @relation(fields: [userId], references: [id])
  integrations            WebsiteIntegration[]

  @@index([businessId])
  @@index([serviceId])
  @@index([isTemplate, templateType])
  @@map("forms")
}

model Service {
  id           String        @id @default(cuid())
  businessId   String
  name         String
  description  String?
  duration     String?
  bufferTime   String?
  price        String?
  currency     String?
  color        String?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  teamMemberId String

  appointments Appointment[]
  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  teamMember   TeamMember    @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  form         Form?

  @@index([businessId])
  @@index([teamMemberId])
  @@map("services")
}

model Appointment {
  id              String            @id @default(cuid())
  businessId      String
  serviceId       String
  teamMemberId    String
  title           String
  description     String?
  start           DateTime
  end             DateTime
  status          AppointmentStatus @default(PENDING)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  backgroundColor String?
  deleted         Boolean           @default(false)
  formId          String?
  customerId      String?
  content         Json?
  business        Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  form            Form?             @relation(fields: [formId], references: [id], onDelete: SetNull)
  service         Service           @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  teamMember      TeamMember        @relation(fields: [teamMemberId], references: [id], onDelete: Restrict)
  customer        Customer?         @relation(fields: [customerId], references: [id], onDelete: Restrict)

  @@index([businessId])
  @@index([businessId, deleted])
  @@index([serviceId])
  @@index([teamMemberId])
  @@index([start, end])
  @@index([start, end, deleted])
  @@map("appointments")
}

model WebsiteIntegration {
  id              String   @id @default(cuid())
  businessId      String
  formId          String
  integrationType String
  embedCode       String?
  settings        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  form            Form     @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@map("website_integrations")
}

model CalendarIntegration {
  id             String    @id @default(cuid())
  userId         String
  provider       String
  accessToken    String
  refreshToken   String?
  tokenExpiresAt DateTime?
  calendarId     String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("calendar_integrations")
}

model Subscription {
  id                   String              @id @default(cuid())
  userId               String
  planName             String
  status               String
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean             @default(false)
  stripeSubscriptionId String
  stripeCustomerId     String
  stripePriceId        String
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  limits               SubscriptionLimits?
  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("subscriptions")
}

model SubscriptionLimits {
  id                      String       @id @default(cuid())
  subscriptionId          String       @unique
  maxBusinesses           Int?
  maxForms                Int?
  maxTeamMembers          Int?
  maxAppointmentsPerMonth Int?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
  subscription            Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@map("subscription_limits")
}

model TeamMemberInvitation {
  id         String   @id @default(cuid())
  businessId String
  email      String
  role       String
  invitedBy  String
  token      String   @unique
  expiresAt  DateTime
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  inviter    User     @relation("Inviter", fields: [invitedBy], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([email])
  @@index([token])
  @@map("team_member_invitations")
}

model Customer {
  id           String        @id @default(cuid())
  businessId   String
  firstName    String
  lastName     String
  email        String?
  phone        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([businessId])
  @@index([businessId, email])
  @@map("customers")
}

view vw_forms_public {
  id         String @unique
  businessId String?
  content    String?
  url        String?
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum FormStatus {
  DRAFT
  LIVE
  ARCHIVED
}
