// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
  previewFeatures = ["views"]
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

model User {
  id String @id @default(cuid())

  email         String    @unique
  isActive      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  emailVerified DateTime?
  firstName     String?
  lastName      String?
  phone         String?
  lastLoginAt   DateTime?
  image         String?
  name          String?

  businesses           Business[]
  teamMemberships      TeamMember[]
  calendarIntegrations CalendarIntegration[]
  subscriptions        Subscription[]
  sentInvitations      TeamMemberInvitation[] @relation("Inviter")
  forms                Form[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_token")
}

model Business {
  id           String   @id @default(cuid())
  ownerId      String
  name         String
  description  String?
  businessType String?
  logoUrl      String?
  primaryColor String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  owner         User                 @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  teamMembers   TeamMember[]
  businessHours BusinessHours[]
  breakTimes    BreakTime[]
  timeOffs      TimeOff[]
  forms         Form[]
  services      Service[]
  appointments  Appointment[]
  integrations  WebsiteIntegration[]
  invitations   TeamMemberInvitation[]

  @@index([ownerId])
  @@index([businessType])
  @@map("businesses")
}

model TeamMember {
  id         String   @id @default(cuid())
  businessId String
  userId     String
  role       String // admin, manager, staff
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  timeOffs     TimeOff[]

  @@unique([businessId, userId])
  @@index([businessId])
  @@index([userId])
  @@map("team_members")
}

model BusinessHours {
  id         String   @id @default(cuid())
  businessId String
  dayOfWeek  String[]
  openTime   String
  closeTime  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, dayOfWeek])
  @@unique([businessId, dayOfWeek])
  @@map("business_hours")
}

model BreakTime {
  id         String   @id @default(cuid())
  businessId String
  dayOfWeek  String[] // 0-6 (Sunday-Saturday)
  startTime  String
  endTime    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, dayOfWeek])
  @@unique([businessId, dayOfWeek])
  @@map("break_times")
}

model TimeOff {
  id           String    @id @default(cuid())
  businessId   String
  teamMemberId String?
  startDate    DateTime  @db.Date
  endDate      DateTime  @db.Date
  startTime    DateTime? @db.Time()
  endTime      DateTime? @db.Time()
  description  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  business   Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  teamMember TeamMember? @relation(fields: [teamMemberId], references: [id], onDelete: SetNull)

  @@map("time_off")
}

enum FormStatus {
  DRAFT
  LIVE
  ARCHIVED
}

model Form {
  id                      String   @id @default(cuid())
  businessId              String
  userId                  String?
  name                    String
  description             String?
  isTemplate              Boolean  @default(false)
  templateType            String?
  confirmationMessage     String?
  url                     String?  @unique
  allowCancellation       Boolean  @default(true)
  cancellationNoticeHours Int      @default(24)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  status                  FormStatus   @default(DRAFT)
  content                 String   @default("[]")

  business     Business             @relation(fields: [businessId], references: [id])
  user         User?                @relation(fields: [userId], references: [id])
  fields       FormField[]
  services     Service[]
  integrations WebsiteIntegration[]
  submissions  FormSubmission[]
  @@index([businessId])
  @@index([isTemplate, templateType])
  @@map("forms")
}

enum FieldVariant {
  CHECKBOX
  COMBOBOX
  DATEPICKER
  TEXT_INPUT
  SELECT
  SWITCH
  TEXTAREA
  TIMEPICKER
  COLOR_PICKER
  TAG_INPUT
  MULTISELECT
  NUMBER_INPUT
  EMAIL_INPUT
  PHONE_INPUT
}

model FormField {
  id              String   @id @default(cuid())
  formId          String
  fieldVariant    FieldVariant
  label           String
  placeholder     String?
  helpText        String?
  isRequired      Boolean  @default(false)
  fieldOrder      Int
  defaultValue    String?
  validationRules Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  options         Json[]

  form Form @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId])
  @@map("form_fields")
}

model FormSubmission {
  id String @id @default(cuid())
  formId String
  submissionData Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  form Form @relation(fields: [formId], references: [id], onDelete: Cascade)
  @@map("form_submissions")
}

model Service {
  id          String   @id @default(cuid())
  businessId  String
  name        String
  description String?
  duration    String? // in minutes
  bufferTime  String? // in minutes
  price       String?
  currency    String?
  color       String?
  formId      String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  form         Form?         @relation(fields: [formId], references: [id], onDelete: SetNull)
  appointments Appointment[]

  @@index([businessId])
  @@map("services")
}

model Appointment {
  id            String   @id @default(cuid())
  businessId    String
  serviceId     String?
  teamMemberId  String?
  customerName  String
  customerEmail String
  customerPhone String?
  title         String
  description   String?
  start         DateTime
  end           DateTime
  status        String   @default("confirmed") // confirmed, cancelled, completed, no-show
  notes         String?
  formData      Json? // Stores the form submission data
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  backgroundColor          String?

  business   Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  service    Service?              @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  teamMember TeamMember?           @relation(fields: [teamMemberId], references: [id], onDelete: SetNull)
  reminders  AppointmentReminder[]

  @@index([businessId])
  @@index([serviceId])
  @@index([teamMemberId])
  @@index([start, end])
  @@index([status])
  @@map("appointments")
}

model AppointmentReminder {
  id            String    @id @default(cuid())
  appointmentId String
  reminderType  String // email, sms
  scheduledTime DateTime
  sentAt        DateTime?
  status        String    @default("pending") // pending, sent, failed
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@map("appointment_reminders")
}

model WebsiteIntegration {
  id              String   @id @default(cuid())
  businessId      String
  formId          String
  integrationType String // embed, wordpress, webflow
  embedCode       String?
  settings        Json? // Integration-specific settings
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  form     Form     @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@map("website_integrations")
}

model CalendarIntegration {
  id             String    @id @default(cuid())
  userId         String
  provider       String // google, outlook, apple
  accessToken    String
  refreshToken   String?
  tokenExpiresAt DateTime?
  calendarId     String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("calendar_integrations")
}

model Subscription {
  id                   String   @id @default(cuid())
  userId               String
  planName             String // starter, business_pro
  status               String // active, canceled, past_due
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean  @default(false)
  stripeSubscriptionId String
  stripeCustomerId     String
  stripePriceId        String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user   User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  limits SubscriptionLimits?

  @@index([userId])
  @@index([status])
  @@map("subscriptions")
}

model SubscriptionLimits {
  id                      String   @id @default(cuid())
  subscriptionId          String   @unique
  maxBusinesses           Int?
  maxForms                Int?
  maxTeamMembers          Int?
  maxAppointmentsPerMonth Int?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@map("subscription_limits")
}

model TeamMemberInvitation {
  id          String   @id @default(cuid())
  businessId  String
  email       String
  role        String
  invitedBy   String
  token       String   @unique
  expiresAt   DateTime
  status      String   @default("pending") // pending, accepted, expired
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  inviter  User     @relation("Inviter", fields: [invitedBy], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([email])
  @@index([token])
  @@map("team_member_invitations")
}

// TODO: Add a view to migrations
view VwFormsPublic {
  id     String  @unique
  content  Json  
  url      String   @unique

  @@map("vw_forms_public")
}